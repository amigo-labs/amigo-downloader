# Dev image: runs Vite dev server with HMR
# Source code is expected to be volume-mounted at /app/web-ui
FROM node:22-alpine3.21

RUN corepack enable
WORKDIR /app

# Install dependencies (cached layer)
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY web-ui/package.json web-ui/
COPY packages/ui/package.json packages/ui/
RUN pnpm install --frozen-lockfile --filter amigo-web-ui...

# Source code is mounted as volume at runtime — do NOT build here.
# Use docker-compose.dev.yml to mount the full web-ui/ + packages/ui/ directories.

WORKDIR /app/web-ui
EXPOSE 5173
CMD ["pnpm", "dev", "--", "--host", "0.0.0.0"]
