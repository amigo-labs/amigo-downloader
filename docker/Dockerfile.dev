# Dev image: builds web-ui at container start, watches for changes
FROM node:22-alpine

WORKDIR /app/web-ui

# Install dependencies (cached layer)
COPY web-ui/package.json web-ui/package-lock.json ./
RUN npm ci

# Source code is mounted as volume at runtime
# Entrypoint builds and starts vite dev server

EXPOSE 5173
ENTRYPOINT ["sh", "-c", "npm run build && npm run dev -- --host 0.0.0.0"]
