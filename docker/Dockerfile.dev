# Dev image: runs Vite dev server with HMR
# Source code is expected to be volume-mounted at /app/web-ui
FROM node:22.14.0-alpine3.21

WORKDIR /app/web-ui

# Install dependencies (cached layer)
COPY web-ui/package.json web-ui/package-lock.json ./
RUN npm ci

# Source code is mounted as volume at runtime — do NOT build here.
# Use docker-compose.dev.yml to mount the full web-ui/ directory.

EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
