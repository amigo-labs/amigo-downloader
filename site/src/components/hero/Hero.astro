---
import MascotFloat from "./MascotFloat.astro";
import TerminalDemo from "./TerminalDemo.svelte";
---

<section class="relative overflow-hidden">
  <div class="hero-backdrop" aria-hidden="true"></div>
  <div class="container-prose relative pt-20 pb-16 md:pt-28 md:pb-24 grid gap-10 md:grid-cols-[1.1fr_1fr] items-center">
    <div>
      <div class="flex items-center gap-3 mb-6">
        <span class="stat-label">Release v0.x · Rust 2024</span>
        <span class="inline-block h-1 w-1 rounded-full" style="background: var(--neon-primary); box-shadow: var(--neon-glow-sm)"></span>
        <span class="stat-label">MIT · self-hosted</span>
      </div>
      <h1
        class="text-4xl md:text-6xl font-bold tracking-tight leading-[1.05] mb-6"
        style="color: var(--text-primary)"
      >
        The download manager <span class="neon-text-primary">power users</span>
        actually want.
      </h1>
      <p class="text-lg md:text-xl max-w-xl mb-8" style="color: var(--text-secondary)">
        Multi-chunk HTTP. Native Usenet with PAR2 repair. HLS, DASH, YouTube. A sandboxed
        TypeScript plugin system. All in a single Rust binary — with a Web UI, CLI, and
        Tauri desktop app.
      </p>
      <div class="flex flex-wrap gap-3 mb-6">
        <a href="#install" class="btn btn-primary">
          <span aria-hidden="true">↓</span>
          Install
        </a>
        <a
          href="https://github.com/amigo-labs/amigo-downloader"
          class="btn btn-ghost"
          target="_blank"
          rel="noopener"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          Star on GitHub
        </a>
      </div>
      <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm" style="color: var(--text-secondary)">
        <li>8 parallel chunks</li>
        <li>· NZB + PAR2</li>
        <li>· TS plugin sandbox</li>
        <li>· Click'n'Load 9666</li>
      </ul>
    </div>

    <div class="flex justify-center md:justify-end gap-8 items-center">
      <MascotFloat size={128} />
      <TerminalDemo client:load />
    </div>
  </div>
</section>
